{
  "name": "mikiz-back",
  "version": "0.1.0",
  "module": "src/index.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run scripts/seed.ts",
    "artists:schedule": "bun run scripts/schedule-artists.ts",
    "artists:set": "bun run scripts/set-artist.ts",
    "artists:delete": "bun run scripts/delete-artists.ts",
    "artists:backfill": "bun run scripts/backfill-artists.ts",
    "films:set": "bun run scripts/set-film.ts",
    "films:schedule": "bun run scripts/schedule-films.ts",
    "films:delete": "bun run scripts/delete-films.ts",
    "politicians:schedule": "bun run scripts/schedule-politicians.ts",
    "politicians:set": "bun run scripts/set-politician.ts",
    "politicians:delete": "bun run scripts/delete-politicians.ts",
    "footballers:fetch": "bun run scripts/fetch-footballers.ts",
    "footballers:schedule": "bun run scripts/schedule-footballers.ts",
    "footballers:set": "bun run scripts/set-footballer.ts",
    "chainapan:seed": "bun run scripts/seed-chainapan.ts",
    "chainapan:set": "bun run scripts/set-chainapan.ts",
    "chainapan:delete": "bun run scripts/delete-chainapan.ts",
    "words:build": "bun run scripts/build-word-lists.ts",
    "words:schedule": "bun run scripts/schedule-words.ts",
    "words:delete": "bun run scripts/delete-words.ts",
    "words:set": "bun run scripts/set-word.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.20",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.2"
  }
}
